---
import { useTranslations } from '../../i18n/utils';
import CopyButton from '../react/CopyButton';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Extract the name to style it with gradient
const titleRaw = t('hero.title');
const nameIndex = titleRaw.indexOf('Tomas Olaya Diaz');
const part1 = titleRaw.substring(0, nameIndex);
const part2 = titleRaw.substring(nameIndex + 'Tomas Olaya Diaz'.length);
---
<section id="hero" class="min-h-[85vh] flex flex-col justify-center max-w-6xl mx-auto px-4 sm:px-6 relative">
  <div class="max-w-4xl">
    <div class="inline-block px-4 py-1.5 mb-6 rounded-full glass-panel text-sm font-semibold text-cyan-600 dark:text-cyan-400 animate-fade-in">
      🚀 {lang === 'es' ? 'Desarrollador Backend & Entusiasta de Seguridad' : 'Backend Developer & Security Enthusiast'}
    </div>
    
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight animate-fade-in delay-100">
      {part1}<span class="bg-clip-text text-transparent bg-gradient-to-r from-cyan-500 to-purple-600">Tomas Olaya Diaz</span>{part2}
    </h1>
    
    <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 mb-10 leading-relaxed max-w-3xl animate-fade-in delay-200">
      {t('hero.subtitle')}
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 animate-fade-in delay-300">
      <a href="#projects" class="btn-primary text-center">
        {t('hero.cta.projects')}
      </a>
      <CopyButton 
        client:load 
        textToCopy="tomasdi.dev@gmail.com" 
        tooltipText={t('copy.tooltip')} 
        copiedText={t('copy.copied')} 
        displayLabel={t('hero.copyEmail')}
        variant="outline" 
      />
    </div>
  </div>
</section>
