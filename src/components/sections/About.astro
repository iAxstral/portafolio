---
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section id="about" class="py-24 max-w-6xl mx-auto px-4 sm:px-6 relative">
  <h2 class="text-3xl md:text-5xl font-bold mb-12 flex items-center gap-4">
    <span class="text-cyan-500">01.</span> {t('about.title')}
    <div class="h-[1px] bg-slate-300 dark:bg-slate-700 flex-grow ml-4"></div>
  </h2>
  
  <div class="grid md:grid-cols-2 gap-12 items-center">
    <div class="space-y-6 text-lg text-slate-700 dark:text-slate-300">
      <p class="glass-panel p-6 border-l-4 border-l-cyan-500">{t('about.p1')}</p>
      <p class="glass-panel p-6 border-l-4 border-l-purple-500">{t('about.p2')}</p>
      <p class="glass-panel p-6 border-l-4 border-l-orange-500">{t('about.p3')}</p>
      
      <div class="mt-8 p-4 bg-gradient-to-r from-cyan-500/10 to-purple-500/10 rounded-xl border border-cyan-500/20 flex items-start gap-4">
        <div class="text-2xl mt-1">💪</div>
        <p class="font-medium text-slate-800 dark:text-slate-200">
          {t('about.gym')}
        </p>
      </div>
    </div>
    
    <div class="relative group mx-auto w-full max-w-md">
      <div class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-purple-600 rounded-2xl blur opacity-25 group-hover:opacity-75 transition duration-1000 group-hover:duration-200"></div>
      <div class="relative glass-panel aspect-square rounded-2xl overflow-hidden flex items-center justify-center bg-slate-100 dark:bg-slate-800">
        <!-- Placeholder for a picture or an abstract 3D icon -->
        <div class="text-9xl opacity-50">👨‍💻</div>
      </div>
    </div>
  </div>
</section>
