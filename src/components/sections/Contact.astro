---
import { useTranslations } from '../../i18n/utils';
import CopyButton from '../react/CopyButton';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section id="contact" class="py-24 max-w-4xl mx-auto px-4 sm:px-6 text-center">
  <h2 class="text-3xl md:text-5xl font-bold mb-8">
    {t('contact.title')}
  </h2>
  <div class="h-1 w-24 bg-gradient-to-r from-cyan-500 to-purple-600 mx-auto mb-12 rounded-full"></div>
  
  <p class="text-lg text-slate-600 dark:text-slate-300 mb-12 max-w-2xl mx-auto leading-relaxed">
    {lang === 'es' 
      ? 'Actualmente estoy abierto a nuevas oportunidades. Si tienes una pregunta, una propuesta, o simplemente quieres saludar, haré todo lo posible para responderte a la brevedad.' 
      : 'I am currently open to new opportunities. Whether you have a question, a proposal, or just want to say hi, I will try my best to get back to you!'}
  </p>
  
  <div class="flex flex-col items-center gap-10">
    <div class="flex gap-6">
      <a href="https://github.com/iAxstral" target="_blank" rel="noopener noreferrer" class="p-4 rounded-full glass-panel hover:scale-110 hover:-translate-y-2 hover:shadow-[0_0_20px_rgba(6,182,212,0.4)] transition-all duration-300 group" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-cyan-500 transition-colors"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
      </a>
      <a href="https://www.linkedin.com/in/tomas-diaz-222357294/" target="_blank" rel="noopener noreferrer" class="p-4 rounded-full glass-panel hover:scale-110 hover:-translate-y-2 hover:shadow-[0_0_20px_rgba(6,182,212,0.4)] transition-all duration-300 group" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-cyan-500 transition-colors"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      </a>
    </div>
    
    <div class="mt-4 w-full sm:w-auto">
      <CopyButton 
        client:visible
        textToCopy="tomasdi.dev@gmail.com"
        tooltipText={t('copy.tooltip')}
        copiedText={t('copy.copied')}
        displayLabel={t('contact.copyEmail')}
        variant="primary"
        className="px-8 py-4 text-lg w-full sm:w-auto shadow-[0_0_20px_rgba(6,182,212,0.3)]"
      />
    </div>
  </div>
  
  <footer class="mt-24 text-sm text-slate-500 dark:text-slate-400">
    <p>© {new Date().getFullYear()} Tomas Olaya Diaz. Built with Astro & Tailwind CSS.</p>
  </footer>
</section>
